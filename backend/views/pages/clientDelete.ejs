<section class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
  <div>
    <h2 class="h5 mb-1 text-danger">Delete Client</h2>
    <p class="text-muted mb-0">You are deleting client ID: <strong><%= client.id %></strong></p>
  </div>
  <a class="btn btn-outline-secondary btn-sm" href="/clients/<%= client.id %>">Back to Profile</a>
</section>

<section class="card border-danger shadow-sm">
  <div class="card-body">
    <p class="mb-3">This action is permanent and cannot be undone.</p>

    <ul class="list-group mb-4">
      <li class="list-group-item"><strong>Full Name:</strong> <%= client.fullName %></li>
      <li class="list-group-item"><strong>Email:</strong> <%= client.email %></li>
      <li class="list-group-item"><strong>Risk Category:</strong> <%= client.riskCategory %></li>
      <li class="list-group-item"><strong>Created Date:</strong> <%= client.createdDate %></li>
    </ul>

    <form method="post" action="/clients/<%= client.id %>/delete" class="d-flex gap-2">
      <button type="submit" class="btn btn-danger">Confirm Delete</button>
      <a class="btn btn-outline-secondary" href="/clients/<%= client.id %>">Cancel</a>
    </form>
  </div>
</section>
